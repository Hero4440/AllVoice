{
  "enabled": true,
  "name": "Build Check After Task",
  "description": "Runs the project build after each spec task is completed to catch build errors early.",
  "version": "1",
  "when": {
    "type": "postTaskExecution"
  },
  "then": {
    "type": "runCommand",
    "command": "export NVM_DIR=\"$HOME/.nvm\" && [ -s \"$NVM_DIR/nvm.sh\" ] && . \"$NVM_DIR/nvm.sh\" && npm run build",
    "timeout": 60
  }
}